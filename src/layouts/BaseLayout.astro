---
/**
 * Base layout — SEO meta, Open Graph/Twitter cards, canonical, JSON-LD,
 * header/footer, sticky mobile CTA. Every page uses this.
 */
import '@fontsource-variable/archivo';
import '@fontsource-variable/inter';
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCta from '../components/StickyCta.astro';
import LocalBusinessSchema from '../components/LocalBusinessSchema.astro';
import { SITE, FIELDD_BOOKING_URL } from '../consts';

interface Props {
  title: string;
  description: string;
  /** Path to social share image, defaults to site-wide OG image */
  ogImage?: string;
  /**
   * Minimal chrome for the ceramic landing page: stripped header/footer,
   * fewer exit points for paid traffic.
   */
  minimal?: boolean;
  /** Booking URL for the sticky mobile bar (ceramic page overrides) */
  stickyCtaHref?: string;
  stickyCtaLabel?: string;
}

const {
  title,
  description,
  ogImage = SITE.ogImage,
  minimal = false,
  stickyCtaHref = FIELDD_BOOKING_URL,
  stickyCtaLabel = 'Book Now',
} = Astro.props;

// Canonical without the .html the file-format build produces in dev
const canonicalPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/$/, '') || '/';
const canonical = new URL(canonicalPath, SITE.url).href;
const ogImageUrl = new URL(ogImage, SITE.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo_32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/logo_16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/logo_180.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0a0d12" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <LocalBusinessSchema />
    <slot name="head" />

    <!-- Meta Pixel Code -->
    <script is:inline>
      !function(f,b,e,v,n,t,s)
      {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
      n.callMethod.apply(n,arguments):n.queue.push(arguments)};
      if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
      n.queue=[];t=b.createElement(e);t.async=!0;
      t.src=v;s=b.getElementsByTagName(e)[0];
      s.parentNode.insertBefore(t,s)}(window, document,'script',
      'https://connect.facebook.net/en_US/fbevents.js');
      fbq('init', '1495570652308586');
      fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=1495570652308586&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-brand focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>
    <Header minimal={minimal} />
    <main id="main">
      <slot />
    </main>
    <Footer minimal={minimal} />
    <StickyCta href={stickyCtaHref} label={stickyCtaLabel} />

    <!-- Meta Pixel "Lead" on every Fieldd booking CTA, sitewide.
         Plain delegated listener (capture phase) — no framework, works on all
         static pages and fires synchronously on click, before navigation
         starts; fbevents delivers via beacon so it survives the redirect. -->
    <script is:inline>
      document.addEventListener(
        'click',
        function (e) {
          var t = e.target;
          var a = t && t.closest && t.closest('a[href*="polishedmidwest.fieldd.co"]');
          if (a && typeof window.fbq === 'function') {
            window.fbq('track', 'Lead');
          }
        },
        true
      );
    </script>
  </body>
</html>
