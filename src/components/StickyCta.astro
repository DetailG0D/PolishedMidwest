---
/**
 * Sticky mobile CTA bar — slides up after the visitor scrolls past the hero.
 * Book Now → Fieldd (same tab) + tap-to-call. Mobile only (hidden md+).
 */
import { NAP, FIELDD_BOOKING_URL } from '../consts';

interface Props {
  /** Booking URL override (ceramic page passes its own deep link) */
  href?: string;
  label?: string;
}
const { href = FIELDD_BOOKING_URL, label = 'Book Now' } = Astro.props;
---

<div
  id="sticky-cta"
  class="fixed inset-x-0 bottom-0 z-50 translate-y-full border-t border-white/10 bg-ink-800/95 backdrop-blur transition-transform duration-300 md:hidden"
  style="padding-bottom: env(safe-area-inset-bottom)"
>
  <div class="flex items-stretch gap-2 p-3">
    <a
      href={NAP.phoneHref}
      class="flex items-center justify-center rounded-md border border-slate-600 px-4 text-white"
      aria-label={`Call ${NAP.phone}`}
    >
      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M2 3.6C2 2.7 2.7 2 3.6 2h2.2c.8 0 1.4.5 1.6 1.2l.8 2.9c.2.6 0 1.3-.5 1.7l-1.2 1a12.9 12.9 0 004.7 4.7l1-1.2c.4-.5 1.1-.7 1.7-.5l2.9.8c.7.2 1.2.8 1.2 1.6v2.2c0 .9-.7 1.6-1.6 1.6H15C7.8 18 2 12.2 2 5V3.6z" />
      </svg>
    </a>
    <a
      href={href}
      class="flex flex-1 items-center justify-center rounded-md bg-brand px-6 py-3.5 font-display text-base font-bold uppercase tracking-wide text-white"
    >
      {label}
    </a>
  </div>
</div>

<script>
  const bar = document.getElementById('sticky-cta');
  let shown = false;
  const onScroll = () => {
    const show = window.scrollY > 500;
    if (show !== shown) {
      shown = show;
      bar?.classList.toggle('translate-y-full', !show);
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
