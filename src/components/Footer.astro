---
/**
 * Footer with NAP (name, address/area, phone) for local SEO.
 * `minimal` (ceramic landing page): NAP + copyright only, no nav links.
 */
import { NAP, SITE, SERVICE_AREAS, FIELDD_BOOKING_URL } from '../consts';

interface Props {
  minimal?: boolean;
}
const { minimal = false } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-ink-800">
  <div class="container-site py-12 sm:py-16">
    {
      !minimal && (
        <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
          <div>
            <img
              src="/images/polished-midwest-logo.webp"
              alt="Polished Midwest — Luxury Mobile Detailing"
              width="276"
              height="240"
              class="h-20 w-auto"
              loading="lazy"
              decoding="async"
            />
            <p class="mt-4 max-w-xs text-sm leading-relaxed text-slate-400">
              Mobile car detailing &amp; ceramic coating serving {NAP.city}, {NAP.state} and the Metro East.
              We come to you.
            </p>
          </div>
          <div>
            <p class="eyebrow mb-4">Services</p>
            <ul class="space-y-2.5 text-sm text-slate-400">
              <li><a class="hover:text-white" href="/ceramic-coating-belleville">Ceramic Coating</a></li>
              <li><a class="hover:text-white" href="/services">Interior Detailing</a></li>
              <li><a class="hover:text-white" href="/services">Exterior Detailing</a></li>
              <li><a class="hover:text-white" href="/services">Full Detail</a></li>
            </ul>
          </div>
          <div>
            <p class="eyebrow mb-4">Company</p>
            <ul class="space-y-2.5 text-sm text-slate-400">
              <li><a class="hover:text-white" href="/about">About</a></li>
              <li><a class="hover:text-white" href="/gallery">Gallery</a></li>
              <li><a class="hover:text-white" href="/contact-us">Contact</a></li>
              <li><a class="hover:text-white" href={FIELDD_BOOKING_URL}>Book Online</a></li>
            </ul>
          </div>
          <div>
            <p class="eyebrow mb-4">Contact</p>
            <address class="space-y-2.5 text-sm not-italic text-slate-400">
              <p class="font-semibold text-white">{SITE.legalName}</p>
              <p>
                {NAP.city}, {NAP.state} — serving the Metro East
              </p>
              <p>
                <a class="hover:text-white" href={NAP.phoneHref}>{NAP.phone}</a>
              </p>
              <p>Mon–Sat: 8 AM – 8 PM<br />Sunday: Closed</p>
            </address>
          </div>
        </div>
      )
    }

    {
      !minimal && (
        <p class="mt-10 border-t border-white/5 pt-8 text-xs leading-relaxed text-slate-500">
          Serving {SERVICE_AREAS.join(', ')} and surrounding Metro East &amp; St.&nbsp;Louis metro communities.
        </p>
      )
    }

    <div
      class:list={[
        'flex flex-col gap-2 text-xs text-slate-500 sm:flex-row sm:items-center sm:justify-between',
        minimal ? '' : 'mt-6',
      ]}
    >
      <p>
        &copy; {year} {SITE.legalName} · {NAP.city}, {NAP.state} ·{' '}
        <a class="hover:text-slate-300" href={NAP.phoneHref}>{NAP.phone}</a>
      </p>
      <p class="flex gap-4">
        <a class="hover:text-slate-300" href="/privacy">Privacy Policy</a>
        <a class="hover:text-slate-300" href="/terms">Terms of Service</a>
        {minimal && <a class="hover:text-slate-300" href="/">polishedmidwest.com</a>}
      </p>
    </div>
  </div>
</footer>
