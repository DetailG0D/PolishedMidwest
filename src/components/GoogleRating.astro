---
/**
 * Google rating trust element — G logo + gold star row + "5.0 · 35+ Google
 * reviews". Values come from GOOGLE_RATING in src/consts.ts.
 * Used in the homepage hero/trust bar and near the top of the ceramic page.
 */
import { GOOGLE_RATING } from '../consts';

interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={['flex items-center gap-2.5', className]}>
  <!-- Google "G" -->
  <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
    <path fill="#4285F4" d="M23.5 12.27c0-.85-.08-1.66-.22-2.45H12v4.64h6.45a5.52 5.52 0 0 1-2.4 3.62v3h3.88c2.27-2.09 3.57-5.17 3.57-8.81z" />
    <path fill="#34A853" d="M12 24c3.24 0 5.96-1.07 7.94-2.91l-3.88-3.01c-1.07.72-2.45 1.15-4.06 1.15-3.13 0-5.78-2.11-6.72-4.95H1.27v3.11A12 12 0 0 0 12 24z" />
    <path fill="#FBBC04" d="M5.28 14.28a7.2 7.2 0 0 1 0-4.56V6.61H1.27a12 12 0 0 0 0 10.78l4.01-3.11z" />
    <path fill="#EA4335" d="M12 4.77c1.76 0 3.34.61 4.59 1.8l3.44-3.44A11.98 11.98 0 0 0 12 0 12 12 0 0 0 1.27 6.61l4.01 3.11C6.22 6.88 8.87 4.77 12 4.77z" />
  </svg>
  <span class="flex gap-0.5 text-[#FBBC04]" aria-label={`Rated ${GOOGLE_RATING.value} out of 5 stars on Google`}>
    {
      Array.from({ length: 5 }).map(() => (
        <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10 1.5l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 14.9l-5.3 2.7 1-5.8L1.5 7.7l5.9-.9L10 1.5z" />
        </svg>
      ))
    }
  </span>
  <span class="text-sm font-semibold text-white">{GOOGLE_RATING.value}</span>
  <span class="text-sm text-slate-400">· {GOOGLE_RATING.count} Google reviews</span>
</div>
