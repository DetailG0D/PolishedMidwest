---
/**
 * Art-directed hero background: phones get a dedicated portrait crop (from
 * scripts/optimize-images.mjs), larger screens get the landscape original.
 * Only ONE source downloads per device. Eager + high priority (it's the LCP).
 */
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  desktop: ImageMetadata;
  mobile: ImageMetadata;
  alt: string;
  /**
   * Tailwind object-position classes for both breakpoints,
   * e.g. 'object-[45%_60%] md:object-[70%_60%]' — mobile focal point first.
   */
  position?: string;
}
const { desktop, mobile, alt, position = '' } = Astro.props;

const desk = await getImage({ src: desktop, format: 'webp', quality: 72, widths: [1024, 1440, 2000] });
const mob = await getImage({ src: mobile, format: 'webp', quality: 74, widths: [480, 768, 900] });
const fallback = await getImage({ src: desktop, format: 'jpg', quality: 72, width: 1600 });
---

<picture class="block h-full w-full">
  <source media="(max-width: 767px)" type="image/webp" srcset={mob.srcSet.attribute} sizes="100vw" />
  <source media="(min-width: 768px)" type="image/webp" srcset={desk.srcSet.attribute} sizes="100vw" />
  <img
    src={fallback.src}
    alt={alt}
    width={desktop.width}
    height={desktop.height}
    loading="eager"
    fetchpriority="high"
    decoding="async"
    class:list={['h-full w-full object-cover', position || 'object-center']}
  />
</picture>
