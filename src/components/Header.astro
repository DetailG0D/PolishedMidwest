---
/**
 * Site header. `minimal` mode (used on the ceramic landing page) strips the
 * nav down to logo + phone + Book CTA so paid traffic has fewer exit points.
 */
import CtaButton from './CtaButton.astro';
import { NAP, FIELDD_BOOKING_URL } from '../consts';

interface Props {
  minimal?: boolean;
}
const { minimal = false } = Astro.props;

const nav = [
  { href: '/ceramic-coating-belleville', label: 'Ceramic Coating' },
  { href: '/services', label: 'Detailing Services' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/about', label: 'About' },
  { href: '/contact-us', label: 'Contact' },
];
const path = Astro.url.pathname.replace(/\.html$/, '').replace(/\/$/, '') || '/';
---

<header class="sticky top-0 z-40 border-b border-white/5 bg-ink/90 backdrop-blur">
  <div class="container-site flex h-16 items-center justify-between gap-4 sm:h-18">
    <a href="/" class="flex shrink-0 items-center" aria-label="Polished Midwest — home">
      <!-- 2x-resolution trimmed WebP (transparent) generated by scripts/optimize-images.mjs -->
      <img
        src="/images/polished-midwest-logo.webp"
        alt="Polished Midwest — Luxury Mobile Detailing"
        width="276"
        height="240"
        class="h-12 w-auto sm:h-14"
        decoding="async"
      />
    </a>

    {
      !minimal && (
        <nav class="hidden items-center gap-7 lg:flex" aria-label="Main">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                'text-sm font-medium transition-colors hover:text-white',
                path === item.href ? 'text-white' : 'text-slate-400',
              ]}
              aria-current={path === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      )
    }

    {
      /* Minimal (ceramic ad landing) header: logo only — links home so the page
         isn't a dead end, but adds zero competing nav/CTAs. */
      !minimal && (
    <div class="flex items-center gap-3">
      <a
        href={NAP.phoneHref}
        class="hidden items-center gap-2 text-sm font-semibold text-slate-300 hover:text-white sm:flex"
      >
        <svg class="h-4 w-4 text-brand" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M2 3.6C2 2.7 2.7 2 3.6 2h2.2c.8 0 1.4.5 1.6 1.2l.8 2.9c.2.6 0 1.3-.5 1.7l-1.2 1a12.9 12.9 0 004.7 4.7l1-1.2c.4-.5 1.1-.7 1.7-.5l2.9.8c.7.2 1.2.8 1.2 1.6v2.2c0 .9-.7 1.6-1.6 1.6H15C7.8 18 2 12.2 2 5V3.6z" />
        </svg>
        {NAP.phone}
      </a>
      <CtaButton size="md" href={FIELDD_BOOKING_URL}>
        Book Now
      </CtaButton>
      <button
        id="menu-toggle"
        type="button"
        class="-mr-1 p-2 text-slate-300 hover:text-white lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
        </svg>
      </button>
    </div>
      )
    }
  </div>

  {
    !minimal && (
      <nav id="mobile-menu" class="hidden border-t border-white/5 lg:hidden" aria-label="Mobile">
        <div class="container-site flex flex-col py-3">
          {nav.map((item) => (
            <a
              href={item.href}
              class="border-b border-white/5 py-3 text-base font-medium text-slate-300 last:border-0 hover:text-white"
            >
              {item.label}
            </a>
          ))}
        </div>
      </nav>
    )
  }
</header>

<script>
  // No-op on the minimal (ceramic) header — elements simply don't exist there.
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
  });
</script>
