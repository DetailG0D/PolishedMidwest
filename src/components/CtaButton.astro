---
/**
 * ⚠️ PRIMARY BOOKING CTA — every instance of this button links to the Fieldd
 * booking flow. The URL currently points at the ROOT of Fieldd
 * (https://polishedmidwest.fieldd.co/). If/when a booking-type deep link is
 * created in Fieldd (e.g. a dedicated "Ceramic Coating — Free Paint
 * Inspection" service type), update FIELDD_BOOKING_URL / CERAMIC_BOOKING_URL
 * in src/consts.ts — do not hard-code URLs in pages.
 *
 * Opens in the SAME tab by design (mobile conversion).
 */
import { FIELDD_BOOKING_URL } from '../consts';

interface Props {
  /** Override the booking URL (e.g. CERAMIC_BOOKING_URL on the ceramic page) */
  href?: string;
  /** 'solid' = brand-blue primary, 'outline' = secondary, 'white' = on-blue sections */
  variant?: 'solid' | 'outline' | 'white';
  size?: 'md' | 'lg';
  class?: string;
}

const {
  href = FIELDD_BOOKING_URL,
  variant = 'solid',
  size = 'lg',
  class: className = '',
} = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-md font-display font-bold uppercase tracking-wide transition-colors duration-150';
const sizes = {
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3.5 text-base',
};
const variants = {
  solid: 'bg-brand text-white hover:bg-brand-dark shadow-lg shadow-brand/25',
  outline: 'border border-slate-500 text-white hover:border-brand hover:text-brand-light',
  white: 'bg-white text-ink hover:bg-slate-200',
};
---

<a href={href} class:list={[base, sizes[size], variants[variant], className]}>
  <slot>Book Now</slot>
  <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
</a>
