---
/**
 * Side-by-side before/after figure with labels. Both halves crop to fill the
 * container, so give the wrapper an aspect class (e.g. "aspect-[4/3]").
 * Only used for photos confirmed to be the same vehicle/area.
 */
import Photo from './Photo.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  before: ImageMetadata;
  after: ImageMetadata;
  beforeAlt: string;
  afterAlt: string;
  /** Visible caption under the figure */
  caption?: string;
  class?: string;
}
const { before, after, beforeAlt, afterAlt, caption, class: className = 'aspect-[4/3]' } = Astro.props;
const sizes = '(min-width: 640px) 25vw, 50vw';
const widths = [480, 800];
---

<figure>
  <div class:list={['grid grid-cols-2 gap-1 overflow-hidden rounded-lg', className]}>
    <div class="relative h-full overflow-hidden">
      <Photo src={before} alt={beforeAlt} sizes={sizes} widths={widths} />
      <span class="absolute bottom-2 left-2 rounded bg-ink/80 px-2 py-0.5 font-display text-[10px] font-bold uppercase tracking-widest text-white">
        Before
      </span>
    </div>
    <div class="relative h-full overflow-hidden">
      <Photo src={after} alt={afterAlt} sizes={sizes} widths={widths} />
      <span class="absolute bottom-2 left-2 rounded bg-brand px-2 py-0.5 font-display text-[10px] font-bold uppercase tracking-widest text-white">
        After
      </span>
    </div>
  </div>
  {caption && <figcaption class="mt-3 text-sm text-slate-400">{caption}</figcaption>}
</figure>
