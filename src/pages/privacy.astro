---
/**
 * Privacy Policy — Polished Midwest (the business/operator).
 * Plain-English small-business policy reflecting the real stack:
 * Meta Pixel, GoHighLevel chat widget, Fieldd booking, phone/SMS contact.
 *
 * ⚠️ TEMPLATE DISCLAIMER: This is a standard small-business template, NOT
 * legal advice. Have an attorney review it before launch — especially the
 * SMS/TCPA consent language and the Meta Pixel / ad-tracking disclosures,
 * which carry real compliance risk if they don't match actual practice.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { NAP } from '../consts';

const EFFECTIVE_DATE = 'July 5, 2026';
const ENTITY = 'Polished Midwest LLC';
const EMAIL = 'luke.holas@gmail.com';
---

<BaseLayout
  title={`Privacy Policy | ${NAP.name}`}
  description={`How ${NAP.name} collects, uses, and protects your information — including booking, chat, phone/SMS, and advertising tools.`}
>
  <section class="py-16 sm:py-24">
    <div class="container-site max-w-3xl">
      <p class="eyebrow mb-4">Legal</p>
      <h1 class="display text-4xl sm:text-5xl">Privacy Policy</h1>
      <p class="mt-4 text-sm text-slate-500">Effective date: {EFFECTIVE_DATE}</p>

      <div class="mt-10 space-y-10 text-base leading-relaxed text-slate-300 [&_h2]:font-display [&_h2]:text-xl [&_h2]:font-bold [&_h2]:uppercase [&_h2]:tracking-tight [&_h2]:text-white [&_p]:mt-3 [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-6">
        <div>
          <p>
            This Privacy Policy explains how {ENTITY} ("Polished Midwest," "we," "us") collects,
            uses, and protects your information when you visit this website, contact us, or book
            our mobile detailing and ceramic coating services in the Belleville, IL / Metro East area.
            The short version: we collect what we need to schedule and perform your service and to
            run our advertising, and <strong class="text-white">we do not sell your personal information</strong>.
          </p>
        </div>

        <div>
          <h2>What we collect</h2>
          <ul>
            <li><strong class="text-white">Contact and booking details</strong> — name, phone number, email, service address, vehicle information, and service preferences you provide when booking or contacting us.</li>
            <li><strong class="text-white">Chat messages</strong> — anything you send through the chat widget on this site.</li>
            <li><strong class="text-white">Usage data</strong> — pages visited, device/browser information, and general location, collected automatically through cookies and tracking technologies described below.</li>
          </ul>
        </div>

        <div>
          <h2>How we use it</h2>
          <ul>
            <li>To schedule, confirm, and perform your detailing service.</li>
            <li>To contact you about your booking — including by phone and SMS text message. Phone numbers and information you submit are used <strong class="text-white">solely to contact you about booking and providing quotes</strong>, not for unrelated marketing lists.</li>
            <li>To respond to questions sent by chat, phone, or email.</li>
            <li>To measure and improve our advertising (see Meta Pixel below).</li>
          </ul>
          <p>We do not sell or share your personal information with third parties for their own unrelated marketing purposes.</p>
        </div>

        <div>
          <h2>Text messages (SMS)</h2>
          <p>
            If you provide your phone number, we may text you about your quote, booking, or
            appointment. Message and data rates may apply.
            <strong class="text-white"> Reply STOP at any time to opt out of text messages</strong> — we'll stop texting you.
            You can also ask us to remove your number by contacting us (below).
          </p>
        </div>

        <div>
          <h2>Third-party tools we use</h2>
          <ul>
            <li>
              <strong class="text-white">Meta (Facebook) Pixel.</strong> This site uses the Meta Pixel, which collects
              usage and browsing data (such as pages viewed and actions taken) and shares it with Meta
              for advertising, analytics, and retargeting — for example, so we can show ads to people
              who visited this site. Meta may combine this with information it holds about you. See
              <a class="text-brand hover:text-brand-light" href="https://www.facebook.com/privacy/policy/" rel="noopener">Meta's Privacy Policy</a>,
              and manage your ad preferences at
              <a class="text-brand hover:text-brand-light" href="https://www.facebook.com/adpreferences/" rel="noopener">facebook.com/adpreferences</a>.
            </li>
            <li>
              <strong class="text-white">GoHighLevel chat widget.</strong> The chat bubble on this site is provided by
              GoHighLevel (HighLevel Inc.). Messages and contact details you enter in the chat are
              collected and processed through their platform so we can respond to you.
            </li>
            <li>
              <strong class="text-white">Fieldd booking.</strong> Online booking is handled by Fieldd, a third-party
              scheduling platform. Information you enter in the booking flow (at polishedmidwest.fieldd.co)
              is collected and processed by Fieldd and is subject to Fieldd's own privacy practices.
            </li>
          </ul>
        </div>

        <div>
          <h2>Cookies &amp; tracking</h2>
          <p>
            This site uses cookies and similar technologies (including the Meta Pixel described above)
            to make the site work and to measure advertising. You can block or delete cookies in your
            browser settings, and use browser features or extensions to limit tracking. Blocking cookies
            won't stop the site from working — you can still call or book.
          </p>
          <p>
            To help measure our advertising accurately, this site also assigns your browser a random
            anonymous identifier — a string of letters and numbers stored in a cookie and in your
            browser's localStorage. It contains no personal details. When you click a booking button,
            this identifier is sent to Meta with the ad events described above, from both your browser
            and our server, so Meta can match the two reports of the same click for advertising
            measurement. Clearing your browser's cookies and site data removes it.
          </p>
        </div>

        <div>
          <h2>Data retention</h2>
          <p>
            We keep booking and contact records only as long as needed to serve you, handle warranty
            or service follow-ups, and meet ordinary business and legal requirements — then we delete
            or anonymize them.
          </p>
        </div>

        <div>
          <h2>Your rights</h2>
          <p>
            You can ask us at any time to (a) tell you what personal information we hold about you,
            (b) correct it, (c) delete it, or (d) stop contacting you. Email {EMAIL} or call
            <a class="text-brand hover:text-brand-light" href={NAP.phoneHref}>{NAP.phone}</a> and we'll
            handle it promptly. Depending on where you live, you may have additional rights under
            applicable law.
          </p>
        </div>

        <div>
          <h2>Children's privacy</h2>
          <p>
            Our services and this website are intended for adults. We do not knowingly collect
            personal information from children under 13. If you believe a child has provided us
            information, contact us and we will delete it.
          </p>
        </div>

        <div>
          <h2>Changes to this policy</h2>
          <p>
            If we change this policy, we'll post the updated version here with a new effective date.
          </p>
        </div>

        <div>
          <h2>Contact</h2>
          <p>
            {ENTITY} · {NAP.city}, {NAP.stateFull} ·{' '}
            <a class="text-brand hover:text-brand-light" href={NAP.phoneHref}>{NAP.phone}</a> · {EMAIL}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
