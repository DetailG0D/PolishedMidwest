---
/**
 * Terms of Service — Polished Midwest (the business/operator).
 *
 * ⚠️ TEMPLATE DISCLAIMER: This is a standard small-business template, NOT
 * legal advice. Have an attorney review it before launch.
 *
 * Cancellation, payment, and guarantee sections reflect Polished Midwest LLC's
 * actual Service Agreement (July 2026). Intentionally NOT covered because the
 * agreement doesn't address them: weather/rain policy, accepted payment
 * methods/timing, ceramic warranty terms (see CONTENT.md §8).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { NAP, FIELDD_BOOKING_URL } from '../consts';

const EFFECTIVE_DATE = 'July 5, 2026';
const ENTITY = 'Polished Midwest LLC';
const EMAIL = 'luke.holas@gmail.com';
---

<BaseLayout
  title={`Terms of Service | ${NAP.name}`}
  description={`Terms of Service for ${NAP.name} — booking, quotes, service area, cancellations, and guarantees for mobile detailing in Belleville, IL and the Metro East.`}
>
  <section class="py-16 sm:py-24">
    <div class="container-site max-w-3xl">
      <p class="eyebrow mb-4">Legal</p>
      <h1 class="display text-4xl sm:text-5xl">Terms of Service</h1>
      <p class="mt-4 text-sm text-slate-500">Effective date: {EFFECTIVE_DATE}</p>

      <div class="mt-10 space-y-10 text-base leading-relaxed text-slate-300 [&_h2]:font-display [&_h2]:text-xl [&_h2]:font-bold [&_h2]:uppercase [&_h2]:tracking-tight [&_h2]:text-white [&_p]:mt-3 [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-6">
        <div>
          <p>
            These terms apply to detailing and ceramic coating services provided by {ENTITY}
            ("Polished Midwest," "we," "us"). By booking a service, you agree to them.
          </p>
        </div>

        <div>
          <h2>Booking</h2>
          <p>
            Appointments are booked through our online booking platform, Fieldd, at{' '}
            <a class="text-brand hover:text-brand-light" href={FIELDD_BOOKING_URL}>polishedmidwest.fieldd.co</a>,
            or by phone at <a class="text-brand hover:text-brand-light" href={NAP.phoneHref}>{NAP.phone}</a>.
            Your booking is confirmed when you receive a confirmation from us or through Fieldd.
          </p>
        </div>

        <div>
          <h2>Quotes &amp; pricing</h2>
          <p>
            Prices shown online are <strong class="text-white">starting prices and estimates</strong>. Final pricing
            depends on your vehicle's size, type, and condition — larger vehicles (trucks, SUVs,
            minivans) and heavily soiled or neglected vehicles may carry additional charges. Where
            possible we confirm any adjustment with you before starting work. Ceramic coating pricing
            is confirmed at the paint inspection.
          </p>
        </div>

        <div>
          <h2>Service area</h2>
          <p>
            We are a mobile service based in {NAP.city}, {NAP.stateFull}, serving the Metro East /
            St. Louis metro east area — generally within about 25 miles of {NAP.city}. Locations
            outside this area may be declined or quoted a travel fee.
          </p>
        </div>

        <div>
          <h2>At your location</h2>
          <p>
            You agree to provide reasonable access to the vehicle at the scheduled time and a safe,
            legal place to work on it. Please remove personal valuables from the vehicle before your
            appointment; we are not responsible for loss of items left in the vehicle.
          </p>
        </div>

        <div>
          <h2>Cancellations &amp; rescheduling</h2>
          <ul>
            <li>
              Rescheduling within <strong class="text-white">48 hours</strong> of your reserved booking
              time is subject to a <strong class="text-white">$40 fee</strong>, which covers the loss of
              your reserved time slot.
            </li>
            <li>
              Cancelling within <strong class="text-white">4 days</strong> of your reserved booking time
              makes your deposit <strong class="text-white">non-refundable</strong>.
            </li>
          </ul>
        </div>

        <div>
          <h2>Payment</h2>
          <p>
            The fee for your service is the agreed <strong class="text-white">Total Cost</strong> shown
            on your service package order. If a job takes significantly longer than expected, a
            <strong class="text-white"> $50 fee</strong> may apply — we'll inform you before or during
            the job. Deposits are non-refundable as described under Cancellations &amp; Rescheduling.
          </p>
        </div>

        <div>
          <h2>Satisfaction &amp; guarantee</h2>
          <p>
            Every job ends with a customer walkthrough before we leave. No service is guaranteed to
            fully restore your vehicle to any prior or new condition — we perform every service to the
            best condition possible within the available resources, time, and expertise. If you're not
            satisfied after the final inspection, contact us within
            <strong class="text-white"> 24 hours</strong>; concerns raised after 24 hours can't be
            addressed under this policy.
          </p>
        </div>

        <div>
          <h2>Vehicle condition &amp; pre-existing damage</h2>
          <p>
            Detailing cleans and protects — it does not repair. We are not responsible for
            pre-existing damage, including worn or failing clear coat, loose trim, prior scratches
            and dents, aged tint, or aftermarket parts. If we notice a condition that could be
            affected by cleaning (for example, peeling clear coat), we'll point it out before
            proceeding.
          </p>
        </div>

        <div>
          <h2>Limitation of liability</h2>
          <p>
            To the fullest extent permitted by law, our total liability for any claim arising out of
            a service is limited to the amount you paid for that service. We are not liable for
            indirect, incidental, or consequential damages. Nothing in these terms limits liability
            that cannot be limited under applicable law.
          </p>
        </div>

        <div>
          <h2>Disclaimers</h2>
          <p>
            Services are provided "as described" for the package you book. Durability of any
            protective product (wax, sealant, ceramic coating) depends on how the vehicle is used,
            stored, and washed after service. No coating prevents rock chips, collision damage, or
            improper washing.
          </p>
        </div>

        <div>
          <h2>Governing law</h2>
          <p>
            These terms are governed by the laws of the State of Illinois. Any dispute will be
            resolved in the state or federal courts located in Illinois.
          </p>
        </div>

        <div>
          <h2>Contact</h2>
          <p>
            {ENTITY} · {NAP.city}, {NAP.stateFull} ·{' '}
            <a class="text-brand hover:text-brand-light" href={NAP.phoneHref}>{NAP.phone}</a> · {EMAIL}
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
