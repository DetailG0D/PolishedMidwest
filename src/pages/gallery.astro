---
/**
 * Gallery — real customer vehicles, deduped from imagery used elsewhere on
 * the site. Add photos: drop originals in the owner's folder, add a line to
 * scripts/optimize-images.mjs, re-run it, and add an entry below.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaButton from '../components/CtaButton.astro';
import Photo from '../components/Photo.astro';
import { NAP, INSTAGRAM_URL } from '../consts';

import raptor from '../assets/photos/gallery-red-ford-raptor-detailed.jpg';
import alpina from '../assets/photos/gallery-blue-bmw-alpina-b7-detailed.jpg';
import corvette from '../assets/photos/gallery-yellow-corvette-stingray-detailed.jpg';
import jetta from '../assets/photos/gallery-vw-jetta-gli-detailed.jpg';
import modelY from '../assets/photos/gallery-white-tesla-model-y-detailed.jpg';
import sorento from '../assets/photos/gallery-black-kia-sorento-detailed.jpg';
import f350 from '../assets/photos/gallery-black-ford-f350-detailed.jpg';
import bmwX3 from '../assets/photos/gallery-white-bmw-x3-detailed.jpg';
import gle from '../assets/photos/gallery-black-mercedes-gle-detailed.jpg';
import baEngine from '../assets/photos/before-after-engine-bay-detail-mercedes.jpg';
import baTitan from '../assets/photos/before-after-truck-interior-detail.jpg';
import baWheels from '../assets/photos/before-after-gloss-black-wheels-bmw.jpg';

const photos = [
  { src: corvette, alt: 'Yellow Corvette Stingray with glossy paint after detailing, Polished Midwest van in the background' },
  { src: raptor, alt: 'Red Ford F-150 Raptor with deep glossy paint after a full detail in the Metro East' },
  { src: baTitan, alt: 'Before and after interior detail on a Nissan Titan — dirty seats and floor restored to clean' },
  { src: alpina, alt: 'Blue BMW Alpina B7 with mirror finish after detailing in Belleville, IL' },
  { src: modelY, alt: 'White Tesla Model Y with clean glossy paint after mobile detailing' },
  { src: baEngine, alt: 'Before and after engine bay detail on a Mercedes GLC — dusty to clean and dressed' },
  { src: jetta, alt: 'Gray VW Jetta GLI with sharp glossy finish after exterior detail' },
  { src: sorento, alt: 'Black Kia Sorento with glossy paint under a dramatic sky after mobile detailing' },
  { src: baWheels, alt: 'Before and after wheel detail on gloss black BMW wheels — brake dust removed' },
  { src: f350, alt: 'Lifted black Ford Super Duty with glossy paint after a full detail' },
  { src: gle, alt: 'Black Mercedes GLE coupe front view with high gloss finish after detailing' },
  { src: bmwX3, alt: 'White BMW X3 M with clean glossy paint detailed at a Metro East home' },
];
---

<BaseLayout
  title={`Before & After Gallery | Car Detailing Belleville, IL | ${NAP.name}`}
  description={`Real before-and-after results from ${NAP.name} — car detailing and ceramic coating around Belleville, IL and the Metro East.`}
>
  <section class="py-16 sm:py-24">
    <div class="container-site">
      <p class="eyebrow mb-4">Gallery</p>
      <h1 class="display max-w-3xl text-4xl sm:text-5xl">The work speaks for itself.</h1>
      <p class="mt-5 max-w-xl text-lg text-slate-300">
        Every shot below is a real vehicle from a real customer in the Metro East.
      </p>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          photos.map((p) => (
            <div class="aspect-[4/3] overflow-hidden rounded-lg">
              <Photo src={p.src} alt={p.alt} sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw" widths={[480, 960]} />
            </div>
          ))
        }
      </div>

      <div class="mt-10 text-center">
        <a
          href={INSTAGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2.5 rounded-md border border-slate-500 px-7 py-3.5 font-display text-base font-bold uppercase tracking-wide text-white transition-colors hover:border-brand hover:text-brand-light"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.26.07 1.64.07 4.85s0 3.6-.07 4.85c-.05 1.17-.25 1.8-.41 2.23a3.7 3.7 0 0 1-.9 1.38c-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.26.06-1.64.07-4.85.07s-3.6 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.2 15.6 2.2 15.2 2.2 12s0-3.6.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.4 2.2 8.8 2.2 12 2.2zm0 1.76c-3.15 0-3.52.01-4.77.07-1.08.05-1.66.23-2.05.38-.52.2-.88.44-1.27.83-.39.39-.63.75-.83 1.27-.15.39-.33.97-.38 2.05-.06 1.25-.07 1.62-.07 4.77s.01 3.52.07 4.77c.05 1.08.23 1.66.38 2.05.2.52.44.88.83 1.27.39.39.75.63 1.27.83.39.15.97.33 2.05.38 1.25.06 1.62.07 4.77.07s3.52-.01 4.77-.07c1.08-.05 1.66-.23 2.05-.38.52-.2.88-.44 1.27-.83.39-.39.63-.75.83-1.27.15-.39.33-.97.38-2.05.06-1.25.07-1.62.07-4.77s-.01-3.52-.07-4.77c-.05-1.08-.23-1.66-.38-2.05-.2-.52-.44-.88-.83-1.27a3.4 3.4 0 0 0-1.27-.83c-.39-.15-.97-.33-2.05-.38-1.25-.06-1.62-.07-4.77-.07zm0 3.06a4.98 4.98 0 1 1 0 9.96 4.98 4.98 0 0 1 0-9.96zm0 8.2a3.23 3.23 0 1 0 0-6.45 3.23 3.23 0 0 0 0 6.45zm5.18-9.62a1.16 1.16 0 1 1-2.33 0 1.16 1.16 0 0 1 2.33 0z" />
          </svg>
          See more on Instagram
        </a>
      </div>
    </div>
  </section>

  <section class="border-t border-white/5 bg-ink-800 py-16 sm:py-20">
    <div class="container-site text-center">
      <h2 class="display mx-auto max-w-2xl text-3xl sm:text-4xl">Want yours in this gallery?</h2>
      <div class="mt-8">
        <CtaButton>Book Now</CtaButton>
      </div>
    </div>
  </section>
</BaseLayout>
