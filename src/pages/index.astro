---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaButton from '../components/CtaButton.astro';
import SectionHeading from '../components/SectionHeading.astro';
import GoogleRating from '../components/GoogleRating.astro';
import Photo from '../components/Photo.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import HeroImage from '../components/HeroImage.astro';
import GoogleReviews from '../components/GoogleReviews.astro';
import { NAP, SERVICE_AREAS, GOOGLE_RATING, FIELDD_BOOKING_URL, MAINTENANCE_BOOKING_URL } from '../consts';

import heroSupra from '../assets/photos/hero-detailed-white-toyota-supra.jpg';
import heroSupraMobile from '../assets/photos/hero-detailed-white-toyota-supra-mobile.jpg';
import cardCeramic from '../assets/photos/ceramic-coated-hyundai-palisade.jpg';
import cardInterior from '../assets/photos/luxury-suv-interior-after-detail.jpg';
import cardExterior from '../assets/photos/foam-wash-bmw-x7-mobile-detailing.jpg';
import civicBefore from '../assets/photos/before-dirty-black-honda-civic.jpg';
import civicAfter from '../assets/photos/after-detailed-black-honda-civic.jpg';
import seatsBefore from '../assets/photos/before-back-seat-interior.jpg';
import seatsAfter from '../assets/photos/after-back-seat-interior.jpg';
import baWheel from '../assets/photos/before-after-wheel-cleaning-bmw.jpg';
import baHeadlight from '../assets/photos/before-after-headlight-restoration.jpg';

const cardSizes = '(min-width: 768px) 33vw, 100vw';

// High-level only — the full menu lives in Fieldd (see src/pages/services.astro)
const services = [
  {
    title: 'Ceramic Coating',
    href: '/ceramic-coating-belleville',
    price: 'Starting at $447',
    blurb:
      'Years of gloss and protection against Midwest sun, road salt, and grime. Professionally prepped, corrected, and coated.',
    photo: cardCeramic,
    alt: 'Ceramic coated bronze Hyundai Palisade with deep gloss finish, detailed in the Metro East',
  },
  {
    title: 'Interior Detailing',
    href: '/services',
    price: 'Starting at $127',
    blurb:
      'Deep-cleaned carpets, seats, and trim. Stains, pet hair, and odors gone — that new-car feeling back.',
    photo: cardInterior,
    alt: 'Spotless cream leather SUV interior after a deep interior detail',
  },
  {
    title: 'Exterior & Full Detail',
    href: '/services',
    price: 'Starting at $127 · Full Detail from $207',
    blurb:
      'Hand wash, decontamination, wheels, trim, and protection — inside and out packages for every vehicle.',
    photo: cardExterior,
    alt: 'BMW X7 covered in foam during a mobile exterior detail at a Belleville driveway',
  },
];

const steps = [
  {
    title: 'Book Online',
    text: 'Pick your service and a time that works. Booking takes about a minute.',
  },
  {
    title: 'We Come to You',
    text: `Home or work, anywhere in the ${NAP.city} / Metro East area. No dropping your car off, no waiting rooms.`,
  },
  {
    title: 'We Transform It',
    text: 'Meticulous, no-shortcuts detailing with professional products and processes.',
  },
  {
    title: 'Final Walkthrough',
    text: 'You inspect everything with us before we leave. Not happy? We make it right.',
  },
];
---

<BaseLayout
  title={`Car Detailing & Ceramic Coating Belleville, IL | Mobile Detailing Metro East | ${NAP.name}`}
  description={`Premium mobile car detailing and ceramic coating in Belleville, IL. Serving the Metro East and St. Louis metro — we come to you. 5.0★ rated. Book online in 60 seconds.`}
>
  <!-- ============ HERO ============
       One cohesive full-bleed hero on ALL breakpoints: art-directed photo
       (portrait crop <768px, landscape above) behind the text with a dark
       overlay. Mobile focal point is set via the `position` prop. -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0">
      <HeroImage
        desktop={heroSupra}
        mobile={heroSupraMobile}
        alt="Freshly detailed white Toyota Supra with glossy paint in a Belleville, IL driveway — mobile detailing by Polished Midwest"
        position="object-[45%_62%] md:object-[70%_60%]"
      />
      <!-- mobile: vertical scrim keeps white text readable over the photo -->
      <div class="absolute inset-0 bg-gradient-to-b from-ink/90 via-ink/70 to-ink md:hidden"></div>
      <!-- desktop: horizontal scrim keeps the headline in clean negative space -->
      <div class="absolute inset-0 hidden bg-gradient-to-r from-ink via-ink/80 via-45% to-ink/10 md:block"></div>
      <div class="absolute inset-x-0 bottom-0 hidden h-28 bg-gradient-to-t from-ink to-transparent md:block"></div>
    </div>

    <div class="container-site relative py-24 sm:py-32 md:py-36 lg:py-44">
      <p class="eyebrow mb-4">Mobile Detailing · {NAP.city}, {NAP.state} &amp; the Metro East</p>
      <!-- max-w-2xl keeps the headline inside the left scrim zone on desktop,
           clear of the car (which is framed on the right) -->
      <h1 class="display max-w-2xl text-4xl sm:text-5xl lg:text-6xl">
        Showroom Shine.<br />
        <span class="text-brand">Delivered to Your Driveway.</span>
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-300">
        Premium car detailing and ceramic coating that comes to you — home or work,
        anywhere in the Metro East. No shortcuts, no waiting rooms.
      </p>
      <GoogleRating class="mt-7" />
      <div class="mt-6 flex flex-wrap items-center gap-4">
        <CtaButton>Book Now</CtaButton>
        <a
          href="/ceramic-coating-belleville"
          class="inline-flex items-center gap-2 py-3 font-display text-base font-bold uppercase tracking-wide text-white hover:text-brand-light"
        >
          Explore Ceramic Coating
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ TRUST BAR ============ -->
  <section class="border-y border-white/5 bg-ink-800">
    <div class="container-site grid grid-cols-2 gap-6 py-8 text-center sm:grid-cols-4">
      <div>
        <p class="font-display text-2xl font-extrabold text-white">{GOOGLE_RATING.value} ★</p>
        <p class="mt-1 text-xs uppercase tracking-wider text-slate-500">Google Rating</p>
      </div>
      <div>
        <p class="font-display text-2xl font-extrabold text-white">{GOOGLE_RATING.count}</p>
        <p class="mt-1 text-xs uppercase tracking-wider text-slate-500">5-Star Reviews</p>
      </div>
      <div>
        <p class="font-display text-2xl font-extrabold text-white">100%</p>
        <p class="mt-1 text-xs uppercase tracking-wider text-slate-500">Mobile — We Come to You</p>
      </div>
      <div>
        <p class="font-display text-2xl font-extrabold text-white">Metro East</p>
        <p class="mt-1 text-xs uppercase tracking-wider text-slate-500">25-Mile Service Area</p>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES OVERVIEW ============ -->
  <section class="py-20 sm:py-28">
    <div class="container-site">
      <SectionHeading eyebrow="What We Do" title="Detailing done right, wherever your car sits.">
        Three ways to bring your vehicle back — from a deep interior reset to years-long ceramic protection.
      </SectionHeading>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {
          services.map((s) => (
            <a
              href={s.href}
              class="group flex flex-col overflow-hidden rounded-lg border border-ink-600 bg-ink-800 transition-colors hover:border-brand/60"
            >
              <div class="aspect-[4/3] overflow-hidden">
                <Photo src={s.photo} alt={s.alt} sizes={cardSizes} widths={[480, 960]} />
              </div>
              <div class="flex flex-1 flex-col p-6">
                <h3 class="font-display text-xl font-bold uppercase tracking-tight text-white">{s.title}</h3>
                <p class="mt-1.5 text-sm font-bold text-brand-light">{s.price}</p>
                <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-400">{s.blurb}</p>
                <span class="mt-5 inline-flex items-center gap-2 text-sm font-bold uppercase tracking-wide text-brand group-hover:text-brand-light">
                  Learn more
                  <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>

      <!-- Maintenance + fleet — high level, booking/inquiry via Fieldd -->
      <div class="mt-6 grid gap-6 md:grid-cols-2">
        <div class="flex flex-col items-start justify-between gap-4 rounded-lg border border-ink-600 bg-ink-800 p-6 sm:flex-row sm:items-center">
          <div>
            <h3 class="font-display text-lg font-bold uppercase tracking-tight text-white">Maintenance Plans</h3>
            <p class="mt-1 text-sm text-slate-400">
              Recurring visits that keep it looking freshly detailed — <span class="font-semibold text-brand-light">starting at $97</span>
            </p>
          </div>
          <a href={MAINTENANCE_BOOKING_URL} class="shrink-0 py-2 text-sm font-bold uppercase tracking-wide text-brand hover:text-brand-light">
            See Options →
          </a>
        </div>
        <div class="flex flex-col items-start justify-between gap-4 rounded-lg border border-ink-600 bg-ink-800 p-6 sm:flex-row sm:items-center">
          <div>
            <h3 class="font-display text-lg font-bold uppercase tracking-tight text-white">Dealership / Fleet</h3>
            <p class="mt-1 text-sm text-slate-400">
              Custom pricing for 3+ vehicles around the Metro East
            </p>
          </div>
          <a href={FIELDD_BOOKING_URL} class="shrink-0 py-2 text-sm font-bold uppercase tracking-wide text-brand hover:text-brand-light">
            Inquire →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ BEFORE / AFTER ============ -->
  <section class="border-y border-white/5 bg-ink-800 py-20 sm:py-28">
    <div class="container-site">
      <SectionHeading eyebrow="The Proof" title="Before &amp; after. No filters, no tricks." align="center">
        Real vehicles from real customers around the Metro East.
      </SectionHeading>
      <div class="mt-12 grid gap-6 sm:grid-cols-2">
        <BeforeAfter
          before={civicBefore}
          after={civicAfter}
          beforeAlt="Black Honda Civic with dull, dusty neglected paint before detailing"
          afterAlt="Same black Honda Civic with deep glossy paint after a full detail in Belleville, IL"
          caption="Full exterior detail — same car, same driveway."
        />
        <BeforeAfter
          before={seatsBefore}
          after={seatsAfter}
          beforeAlt="Car back seat with crumbs and dirty cloth upholstery before interior detailing"
          afterAlt="Same back seat spotless after interior shampoo and vacuum"
          caption="Interior detail — seats and carpet brought back."
        />
        <figure>
          <div class="aspect-[4/3] overflow-hidden rounded-lg">
            <Photo
              src={baWheel}
              alt="Before and after wheel cleaning on a white BMW — brake dust removed, tire dressed"
              sizes="(min-width: 640px) 50vw, 100vw"
              widths={[640, 1200]}
            />
          </div>
          <figcaption class="mt-3 text-sm text-slate-400">Wheels deep-cleaned and dressed.</figcaption>
        </figure>
        <figure>
          <div class="aspect-[4/3] overflow-hidden rounded-lg">
            <Photo
              src={baHeadlight}
              alt="Before and after headlight restoration — oxidized cloudy lens polished back to clear"
              sizes="(min-width: 640px) 50vw, 100vw"
              widths={[640, 1200]}
            />
          </div>
          <figcaption class="mt-3 text-sm text-slate-400">Headlight restoration — cloudy to clear.</figcaption>
        </figure>
      </div>
      <div class="mt-10 text-center">
        <a
          href="/gallery"
          class="inline-flex items-center gap-2 font-display text-base font-bold uppercase tracking-wide text-brand hover:text-brand-light"
        >
          See the full gallery
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ PROCESS ============ -->
  <section class="py-20 sm:py-28">
    <div class="container-site">
      <SectionHeading eyebrow="How It Works" title="Booked in a minute. Done at your driveway." />
      <ol class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((step, i) => (
            <li class="relative rounded-lg border border-ink-600 bg-ink-800 p-6">
              <span class="font-display text-4xl font-extrabold text-brand/40">0{i + 1}</span>
              <h3 class="mt-3 font-display text-lg font-bold uppercase tracking-tight text-white">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">{step.text}</p>
            </li>
          ))
        }
      </ol>
      <div class="mt-12">
        <CtaButton>Book Now</CtaButton>
      </div>
    </div>
  </section>

  <!-- ============ GUARANTEE ============ -->
  <section class="border-y border-white/5 bg-brand">
    <div class="container-site flex flex-col items-start gap-6 py-14 sm:py-16 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-2xl">
        <h2 class="display text-2xl text-white sm:text-3xl">Our guarantee: you inspect it before we leave.</h2>
        <p class="mt-3 leading-relaxed text-blue-100">
          <!-- [GUARANTEE COPY] Confirm exact guarantee wording with owner — see CONTENT.md -->
          Every job ends with a walkthrough. If anything isn't right, we fix it on the spot — that simple.
        </p>
      </div>
      <CtaButton variant="white">Book Now</CtaButton>
    </div>
  </section>

  <!-- ============ REVIEWS ============ -->
  <GoogleReviews />

  <!-- ============ SERVICE AREA ============ -->
  <section class="border-t border-white/5 bg-ink-800 py-20 sm:py-28">
    <div class="container-site grid items-center gap-12 lg:grid-cols-2">
      <div>
        <SectionHeading eyebrow="Service Area" title={`Serving ${NAP.city} & the Metro East.`}>
          Fully mobile within roughly 25 miles of {NAP.city}, {NAP.state} — including the St.&nbsp;Louis metro east side.
          Don't see your town? Call us at <a href={NAP.phoneHref} class="text-white underline decoration-brand underline-offset-4">{NAP.phone}</a>.
        </SectionHeading>
        <ul class="mt-8 grid grid-cols-2 gap-x-6 gap-y-2 text-sm text-slate-400 sm:grid-cols-3">
          {SERVICE_AREAS.map((town) => (
            <li class="flex items-center gap-2">
              <span class="h-1 w-1 rounded-full bg-brand"></span>
              {town}, IL
            </li>
          ))}
        </ul>
      </div>
      <div>
        <!-- Keyless Google Maps embed, native lazy-loading (below the fold, no page-speed cost) -->
        <div class="aspect-square overflow-hidden rounded-lg border border-ink-600 lg:aspect-[4/5]">
          <iframe
            src="https://www.google.com/maps?q=Belleville%2C+IL&z=9&output=embed"
            title="Map of the Polished Midwest service area — Belleville, IL and the Metro East / St. Louis metro"
            class="h-full w-full border-0"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
        <p class="mt-3 text-center text-xs text-slate-500">
          Fully mobile within ~25 miles of Belleville, IL — Metro East &amp; St.&nbsp;Louis metro east side.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ FINAL CTA ============ -->
  <section class="py-20 sm:py-28">
    <div class="container-site text-center">
      <h2 class="display mx-auto max-w-3xl text-3xl sm:text-5xl">
        Your car is one booking away from looking new again.
      </h2>
      <p class="mx-auto mt-5 max-w-xl text-lg text-slate-400">
        Pick a time online — we'll handle everything else, right at your driveway.
      </p>
      <div class="mt-9 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <CtaButton>Book Now</CtaButton>
        <a href={NAP.phoneHref} class="font-display text-base font-bold uppercase tracking-wide text-slate-300 hover:text-white">
          or call {NAP.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
